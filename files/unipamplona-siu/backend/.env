# ============================================================
# CONFIGURACIÓN DEL ENTORNO — Universidad de Pamplona SIU
# Copia este archivo a .env y ajusta los valores
# NUNCA subas el archivo .env al repositorio
# ============================================================

# Configuración del servidor
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/unipamplona_siu?schema=public"

# JWT — cambia el secreto en producción por uno seguro y largo
JWT_SECRET=tu_secreto_jwt_muy_seguro_cambialo_en_produccion_2025
JWT_EXPIRES_IN=8h

# CORS — origen permitido (frontend)
CORS_ORIGIN=http://localhost:5500

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Bcrypt rounds (12 recomendado para producción)
BCRYPT_ROUNDS=12
